{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".codex-tests",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ES2022",
    "incremental": false,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "lib/domain/**/*.ts",
    "tests/domain/**/*.ts"
  ]
}
