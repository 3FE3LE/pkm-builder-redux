    "fetch:effects": "node scripts/fetch-effect-dex.mjs",
    "fetch:learnsets": "node scripts/fetch-pokemon-learnsets-gen5.mjs",
    "extract:world": "node scripts/extract-world-data.mjs",
    "extract:item-overrides": "node scripts/extract-item-overrides.mjs"
  },
  "dependencies": {
